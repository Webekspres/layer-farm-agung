# Copy to .env and adjust secrets for local development:
#   cp .env.example .env

# PostgreSQL — local Docker DB on host port 5433 (see docker-compose.yml).
# Use 127.0.0.1 (not localhost) to avoid IPv6 routing to a different Postgres instance.
DATABASE_URL="postgresql://layerfarm_user:secretpassword@127.0.0.1:5433/layerfarm_agung_db?schema=public"

# Staging (Neon) — use the *pooled* connection string on Vercel as DATABASE_URL.
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Optional: unpooled/direct URL for `bun run db:migrate:deploy` from your machine:
# DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="generate-a-long-random-secret"
# Use LAN IP when testing mobile on a physical device (must match EXPO_PUBLIC_API_URL).
# On Vercel staging: set both to https://your-app.vercel.app (no trailing slash).
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"
# Opsional — origin tambahan untuk Better Auth (Expo scheme sudah di-hardcode: aapmmobile://)
# BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:8081"

# Expo / mobile — comma-separated origins for CORS on /api/v1/* (required in production/staging)
# MOBILE_CORS_ORIGINS="http://localhost:8081,http://192.168.1.10:8081"

# Object storage — local MinIO (bun run docker:services) OR Cloudflare R2 (staging)
# Local MinIO:
STORAGE_ENDPOINT="http://127.0.0.1:9000"
STORAGE_ACCESS_KEY="aapm_access_key"
STORAGE_SECRET_KEY="aapm_secret_key_123"
STORAGE_BUCKET="aapm-storage"
# Staging R2 (create bucket + API token in Cloudflare dashboard first):
# STORAGE_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
# STORAGE_ACCESS_KEY="<r2_access_key_id>"
# STORAGE_SECRET_KEY="<r2_secret_access_key>"
# STORAGE_BUCKET="aapm-storage"
# STORAGE_REGION="auto"
# STORAGE_FORCE_PATH_STYLE="false"
